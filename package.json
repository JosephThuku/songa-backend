{
  "name": "songa-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Songa backend — Node.js + TypeScript + Express + Prisma + PostgreSQL + Redis",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "predev": "tsx scripts/ensure-prisma-client.ts && prisma db push --skip-generate --accept-data-loss && prisma generate",
    "postinstall": "prisma generate",
    "prepare": "prisma generate",
    "pretest": "tsx scripts/ensure-prisma-client.ts",
    "prebuild": "tsx scripts/ensure-prisma-client.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:audit-orphans": "tsx scripts/audit-orphan-fks.ts",
    "db:repair-orphans": "tsx scripts/repair-orphan-fks.ts",
    "db:backfill-places": "tsx scripts/backfill-place-fks.ts",
    "db:backfill-booking-seats": "tsx scripts/backfill-booking-seats.ts",
    "db:backfill-ride-declines": "tsx scripts/backfill-ride-driver-declines.ts",
    "db:backfill-driver-locations": "tsx scripts/backfill-driver-locations.ts",
    "db:backfill-ride-seats": "tsx scripts/backfill-ride-seats.ts",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:production": "tsx prisma/seed-production.ts",
    "db:seed:shared-rides": "tsx prisma/seed-shared-rides.ts",
    "shared-rides:release-expired-holds": "tsx scripts/release-expired-seat-holds.ts",
    "simulate:ride": "tsx scripts/simulate-ride-flow.ts",
    "user:reset-driver": "tsx scripts/reset-user-by-phone.ts",
    "sms:test": "tsx scripts/test-sms-otp.ts",
    "db:push": "prisma db push",
    "db:sync": "prisma db push && prisma generate",
    "db:ensure-client": "tsx scripts/ensure-prisma-client.ts",
    "db:fix-auth": "tsx scripts/apply-auth-columns.ts && prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npm run typecheck",
    "typecheck": "prisma generate && tsc --noEmit -p tsconfig.build.json"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@prisma/client": "^5.22.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bullmq": "^5.34.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cuid": "^3.0.0",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.11.13",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "dotenv": "^17.4.2",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
