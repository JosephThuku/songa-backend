# Database (MySQL — local dev convention: a dedicated user, NOT root)
DATABASE_URL="mysql://USER:PASS@localhost:3306/songa"
TEST_DATABASE_URL="mysql://USER:PASS@localhost:3306/songa_test"

# Redis (optional — leave empty to use the in-memory fallback; tests use in-memory by default)
REDIS_URL=""

# Auth secrets (REQUIRED)
SESSION_JWT_SECRET="change-me-to-a-long-random-string-min-16-chars"
OTP_PEPPER="change-me-to-another-long-random-string-min-8-chars"

# Server
PORT="4000"
NODE_ENV="development"

# How long a driver's last GPS ping counts as visible (ms). Use 300000+ locally if testing without constant pings.
# DRIVER_LOCATION_FRESH_MS="300000"

# Auto-mark bookings paid after POST /pay (dev/demo only — never in production)
ALLOW_DEV_PAYMENT_CONFIRM="true"

# Safaricom Daraja (M-Pesa) — leave empty to use dev auto-confirm only
# MPESA_ENVIRONMENT=sandbox
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_SHORTCODE=
# Shown in app for manual Paybill / Till checkout (passenger copies on phone)
# SONGA_MPESA_PAYBILL=
# SONGA_MPESA_TILL=
# SONGA_MPESA_BUSINESS_NAME=Songa
# MPESA_PASS_KEY=
# MPESA_B2C_CONSUMER_KEY=
# MPESA_B2C_CONSUMER_SECRET=
# MPESA_B2C_SHORTCODE=
# MPESA_INITIATOR_NAME=
# MPESA_INITIATOR_PASSWORD=
# MPESA_CERTIFICATE_PATH=certs/mpesa.cer
# PUBLIC_API_URL=https://your-api.example.com
# MPESA_STK_CALLBACK_URL=
# MPESA_B2C_RESULT_URL=
# MPESA_B2C_TIMEOUT_URL=

# Places autocomplete — dev defaults to data/dummy-places.json (no Google needed)
USE_DUMMY_PLACES=true
# Seeded driver locations count as fresh for 24h in local dev (60s in production/tests).
# DRIVER_LOCATION_FRESH_MS=86400000
# Set both below only when you want real Google Places in dev:
# USE_DUMMY_PLACES=false
# USE_GOOGLE_PLACES=true
# GOOGLE_PLACES_API_KEY=
# Same key can power traffic-aware driving routes (Directions API):
# GOOGLE_MAPS_API_KEY=

# Routing: with a Google key, ETAs use live traffic (best for Nairobi). Without it, straight-line estimates are used.

# CORS — development: allow any origin (Expo web is often http://localhost:8081)
CORS_ALLOW_ALL=true
# Production: set CORS_ALLOW_ALL=false and list origins, e.g.:
# CORS_ORIGINS="https://app.songa.com,http://localhost:8081"
# Expo tunnel web (*.exp.direct) is auto-allowed in non-production when using an allowlist.
# Ngrok free tier: browser sends OPTIONS without ngrok-skip-browser-warning, so preflight
# may hit ngrok's HTML warning page (no CORS headers). Use localhost:4000 for Expo web,
# disable ngrok browser warning, or test on native (no browser CORS).
CORS_ORIGINS=""

# Expo push notifications — optional. Anonymous Expo push works without it in dev,
# but enhanced-security projects require an access token from
# https://expo.dev/accounts/[account]/settings/access-tokens
# EXPO_ACCESS_TOKEN=""

# SMS (Wasiliana) — https://docs.wasiliana.com/sender-id
# POST {WASILIANA_BASE_URL}/api/v1/send/sms  (header: apiKey)
# Leave WASILIANA_API_KEY empty to console-log OTP in dev (no real SMS).
WASILIANA_API_KEY=""
WASILIANA_SENDER_ID="SONGA"
WASILIANA_BASE_URL="https://api.wasiliana.com"

# --- Shared SGR / coast (optional — defaults shown) ---
# Minutes before van departs that booking/intent is still allowed (to_sgr).
SHARED_RIDES_BOOKING_LEAD_MIN=120
# After train arrival, still suggest from_sgr vans for this many minutes.
SHARED_RIDES_FROM_SGR_GRACE_MIN=45
# How far ahead to show from_sgr arrival vans.
SHARED_RIDES_FROM_SGR_LOOKAHEAD_H=6
# Max one-tap suggestions returned (primary + secondary).
SHARED_RIDES_MAX_SUGGESTIONS=2
# Optional % withheld from shared prepay wallet credit (default 0; not the shared product model)
# SHARED_RIDES_DRIVER_HOLDBACK_PERCENT=0
# Planned: daily driver subscription for shared vans (amount + debit job TBD) — see docs/backlog/shared-rides.md
# Optional web base for call-in pay SMS (else songa:// deep link)
# PAY_INVITE_BASE_URL=https://app.songa.com
