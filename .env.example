# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/songa?schema=public"
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/songa_test?schema=public"

# Redis (optional — leave empty to use in-memory client; tests use in-memory by default)
REDIS_URL=""

# Auth secrets (REQUIRED)
SESSION_JWT_SECRET="change-me-to-a-long-random-string"
OTP_PEPPER="change-me-to-another-long-random-string"

# Server
PORT="4000"
NODE_ENV="development"

# CORS — comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3000,http://localhost:19006"
