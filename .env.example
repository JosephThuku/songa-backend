# Database (MySQL — local dev convention: a dedicated user, NOT root)
DATABASE_URL="mysql://USER:PASS@localhost:3306/songa"
TEST_DATABASE_URL="mysql://USER:PASS@localhost:3306/songa_test"

# Redis (optional — leave empty to use the in-memory fallback; tests use in-memory by default)
REDIS_URL=""

# Auth secrets (REQUIRED)
SESSION_JWT_SECRET="change-me-to-a-long-random-string-min-16-chars"
OTP_PEPPER="change-me-to-another-long-random-string-min-8-chars"

# Server
PORT="4000"
NODE_ENV="development"

# Auto-mark bookings paid after POST /pay (dev/demo only — never in production)
ALLOW_DEV_PAYMENT_CONFIRM="true"

# Places autocomplete — dev defaults to data/dummy-places.json (no Google needed)
USE_DUMMY_PLACES=true
# Seeded driver locations count as fresh for 24h in local dev (60s in production/tests).
# DRIVER_LOCATION_FRESH_MS=86400000
# Set both below only when you want real Google Places in dev:
# USE_DUMMY_PLACES=false
# USE_GOOGLE_PLACES=true
# GOOGLE_PLACES_API_KEY=

# CORS — development: allow any origin (Expo web is often http://localhost:8081)
CORS_ALLOW_ALL=true
# Production: set CORS_ALLOW_ALL=false and list origins, e.g.:
# CORS_ORIGINS="https://app.songa.com,http://localhost:8081"
# Expo tunnel web (*.exp.direct) is auto-allowed in non-production when using an allowlist.
# Ngrok free tier: browser sends OPTIONS without ngrok-skip-browser-warning, so preflight
# may hit ngrok's HTML warning page (no CORS headers). Use localhost:4000 for Expo web,
# disable ngrok browser warning, or test on native (no browser CORS).
CORS_ORIGINS=""

# SMS (Wasiliana) — https://docs.wasiliana.com/sender-id
# POST {WASILIANA_BASE_URL}/api/v1/send/sms  (header: apiKey)
# Leave WASILIANA_API_KEY empty to console-log OTP in dev (no real SMS).
WASILIANA_API_KEY=""
WASILIANA_SENDER_ID="SONGA"
WASILIANA_BASE_URL="https://api.wasiliana.com"
