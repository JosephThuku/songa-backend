// NEW — full initial schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  passenger
  driver
  admin
}

enum OnboardingStatus {
  pending
  approved
  rejected
}

enum RidePhase {
  finding_driver
  driver_accepted
  driver_en_route
  driver_arriving
  driver_arrived
  trip_in_progress
  trip_ended
  cancelled
}

enum BookingMode {
  seat_selection
  pay_on_arrival
}

enum RideEventActor {
  passenger
  driver
  system
}

enum BookingStatus {
  pending_payment
  paid
  failed
  cancelled
}

enum BookingProduct {
  on_demand
  shared_sgr
}

enum PaymentStatus {
  pending
  succeeded
  failed
}

enum SavedPlaceKind {
  home
  work
  other
}

model User {
  id            String    @id @default(cuid())
  phone         String
  role          UserRole
  name          String?
  email         String?
  passwordHash  String?
  phoneVerified Boolean   @default(false)
  avatarUrl     String?
  rating        Float     @default(5.0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  driverProfile      DriverProfile?
  sessions           Session[]
  passengerRides     Ride[]              @relation("PassengerRides")
  driverRides        Ride[]              @relation("DriverRides")
  rideEvents         RideEvent[]
  bookings           Booking[]
  walletTransactions WalletTransaction[]
  notifications      Notification[]
  devices            Device[]
  savedPlaces              SavedPlace[]
  paymentMethods           PaymentMethodPreference[]
  driverSharedDepartures        SharedDeparture[]              @relation("DriverSharedDepartures")
  reservedDepartureSeats        SharedDepartureSeat[]          @relation("ReservedDepartureSeats")
  sharedTripRequestReservations SharedTripRequestReservation[] @relation("PassengerTripRequestReservations")
  rideDriverDeclines            RideDriverDecline[]            @relation("RideDriverDeclines")
  driverLocation                DriverLocation?

  @@unique([phone, role]) // one human can be both passenger AND driver on same #
  @@unique([email, role]) // null emails allowed; uniqueness only enforced when set
  @@index([phone])
}

model DriverProfile {
  id                String           @id @default(cuid())
  userId            String           @unique
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  isOnline          Boolean          @default(false)
  acceptanceRate    Int              @default(100)
  onboardingStatus  OnboardingStatus @default(approved)
  vehicleId         String?
  vehicle           Vehicle?         @relation(fields: [vehicleId], references: [id])
  location          Json?
  locationUpdatedAt DateTime?
  onlineSince       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model Vehicle {
  id             String          @id @default(cuid())
  type           String
  make           String
  model          String
  registration   String          @unique
  color          String
  year           String?
  seats          Int             @default(4)
  /// Laravel `seat_layout`: rows, cols, disabled_seats (e.g. A1).
  seatLayout     Json?
  status         String          @default("Activated")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  driverProfiles DriverProfile[]
  sharedDepartures SharedDeparture[]
}

model Ride {
  id               String          @id
  tripId           String?
  vehicleType      String?
  passengerId      String
  passenger        User            @relation("PassengerRides", fields: [passengerId], references: [id])
  driverId         String?
  driver           User?           @relation("DriverRides", fields: [driverId], references: [id])
  phase            RidePhase       @default(finding_driver)
  bookingMode      BookingMode
  prepaid          Boolean         @default(false)
  bookingId        String?
  paymentMethod    String?
  price            Int
  currency         String          @default("KES")
  etaMinutes       Int?
  distanceKm       Float?
  driverProgress   Float           @default(0)
  passengerBoarded Boolean         @default(false)
  seats            String?
  pickup           Json
  dropoff          Json
  pickupPlaceId    String?
  pickupPlace      Place?          @relation("RidePickupPlace", fields: [pickupPlaceId], references: [id], onDelete: SetNull)
  dropoffPlaceId   String?
  dropoffPlace     Place?          @relation("RideDropoffPlace", fields: [dropoffPlaceId], references: [id], onDelete: SetNull)
  /// Legacy snapshot; live GPS is on DriverLocation (read via driver join).
  driverLocation   Json?
  cancelReason            Json?
  cancelledByRole         RideEventActor?
  passengerDriverRating   Int?
  createdAt               DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  events           RideEvent[]
  driverDeclines   RideDriverDecline[]
  seatRows         RideSeat[]
  booking          Booking?        @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  walletTransactions WalletTransaction[]

  @@index([passengerId, phase])
  @@index([bookingId])
  @@index([pickupPlaceId])
  @@index([dropoffPlaceId])
  @@index([driverId, phase])
  @@index([phase, createdAt])
}

/// Driver declined a dispatch offer for this ride (replaces declinedBy JSON string).
model RideDriverDecline {
  id         String   @id @default(cuid())
  rideId     String
  ride       Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)
  driverId   String
  driver     User     @relation("RideDriverDeclines", fields: [driverId], references: [id], onDelete: Cascade)
  declinedAt DateTime @default(now())

  @@unique([rideId, driverId])
  @@index([rideId])
  @@index([driverId])
}

/// Canonical live driver GPS (single writer via persistDriverLocation).
model DriverLocation {
  driverId  String   @id
  driver    User     @relation(fields: [driverId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  heading   Float?
  speedKmh  Float?
  accuracyM Float?
  updatedAt DateTime

  @@index([updatedAt])
}

/// On-demand ride seat selection (dual-write with Ride.seats string during cutover).
model RideSeat {
  id         String   @id @default(cuid())
  rideId     String
  ride       Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)
  seatNumber Int
  createdAt  DateTime @default(now())

  @@unique([rideId, seatNumber])
  @@index([rideId])
}

model RideEvent {
  id       String         @id @default(cuid())
  rideId   String
  ride     Ride           @relation(fields: [rideId], references: [id], onDelete: Cascade)
  actor    RideEventActor
  actorId  String?
  user     User?          @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action   String
  phase    RidePhase
  metadata Json?
  at       DateTime       @default(now())

  @@index([rideId, at])
}

model Booking {
  id                String         @id
  passengerId       String
  passenger         User           @relation(fields: [passengerId], references: [id], onDelete: Cascade)
  tripId            String?
  product           BookingProduct @default(on_demand)
  sharedDepartureId String?
  sharedDeparture   SharedDeparture? @relation(fields: [sharedDepartureId], references: [id], onDelete: SetNull)
  status            BookingStatus  @default(pending_payment)
  seats             String?
  subtotal          Int
  platformFee       Int            @default(50)
  total             Int
  currency          String         @default("KES")
  pickup            Json
  dropoff           Json
  pickupPlaceId     String?
  pickupPlace       Place?         @relation("BookingPickupPlace", fields: [pickupPlaceId], references: [id], onDelete: SetNull)
  dropoffPlaceId    String?
  dropoffPlace      Place?         @relation("BookingDropoffPlace", fields: [dropoffPlaceId], references: [id], onDelete: SetNull)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  payments          Payment[]
  rides             Ride[]
  departureSeats    SharedDepartureSeat[]
  seatRows          BookingSeat[]

  @@index([passengerId, status])
  @@index([sharedDepartureId])
  @@index([pickupPlaceId])
  @@index([dropoffPlaceId])
}

/// One row per seat sold on a booking (replaces comma-separated Booking.seats over time).
model BookingSeat {
  id                    String               @id @default(cuid())
  bookingId             String
  booking               Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  seatNumber            Int
  sharedDepartureSeatId String?
  sharedDepartureSeat   SharedDepartureSeat? @relation(fields: [sharedDepartureSeatId], references: [id], onDelete: SetNull)
  createdAt             DateTime             @default(now())

  @@unique([bookingId, seatNumber])
  @@index([bookingId])
  @@index([sharedDepartureSeatId])
}

model Payment {
  id                      String        @id
  bookingId               String
  booking                 Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider                String
  status                  PaymentStatus @default(pending)
  checkoutUrl             String?
  reference               String        @unique
  mpesaCheckoutRequestId  String?       @unique
  transactionRef          String?       @unique
  gatewayResponse         Json?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@index([bookingId, createdAt])
}

model WalletTransaction {
  id        String   @id
  driverId  String
  driver    User     @relation(fields: [driverId], references: [id], onDelete: Cascade)
  rideId    String?
  ride      Ride?    @relation(fields: [rideId], references: [id], onDelete: SetNull)
  type      String
  label     String
  amount    Int
  currency  String   @default("KES")
  status    String   @default("posted")
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([driverId, createdAt])
  @@index([rideId])
}

model Notification {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String
  deepLink  String?
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Device {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushToken String   @unique
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model OtpAttempt {
  id        String   @id @default(cuid())
  phone     String
  ip        String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
  @@index([ip, createdAt])
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // SHA-256 of the JWT, for revocation lookup
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// Normalized geographic point; Ride/Booking rows reference immutable snapshots at create time.
model Place {
  id                 String            @id @default(cuid())
  label              String
  lat                Float
  lng                Float
  /// External map provider id (DTO `placeId`).
  externalPlaceId    String?
  corridorLocationId String?
  corridorLocation   CorridorLocation? @relation(fields: [corridorLocationId], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now())

  ridePickups        Ride[]            @relation("RidePickupPlace")
  rideDropoffs       Ride[]            @relation("RideDropoffPlace")
  bookingPickups     Booking[]         @relation("BookingPickupPlace")
  bookingDropoffs    Booking[]         @relation("BookingDropoffPlace")

  @@index([corridorLocationId])
}

model SavedPlace {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  kind      SavedPlaceKind @default(other)
  placeId   String?
  lat       Float
  lng       Float
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId, createdAt])
}

model PaymentMethodPreference {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  isDefault  Boolean  @default(false)
  mpesaPhone String?
  cardLast4  String?
  cardBrand  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, type])
  @@index([userId])
}

// --- Shared SGR / coast corridor (see docs/SHARED_RIDES_PHASE1.md) ---

enum SharedRideDirection {
  to_sgr
  from_sgr
}

enum SgrTrainService {
  inter_county
  express
  night
}

enum SharedDepartureStatus {
  scheduled
  boarding
  completed
  cancelled
}

/// Neighborhood zone or fixed SGR Miritini stop (admin CRUD).
model CorridorLocation {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String   @unique
  lat       Float?
  lng       Float?
  radiusM   Int      @default(2500)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pickupSlots   SgrScheduleSlot[] @relation("SlotPickup")
  dropoffSlots  SgrScheduleSlot[] @relation("SlotDropoff")
  departuresFrom SharedDeparture[] @relation("DeparturePickup")
  departuresTo   SharedDeparture[] @relation("DepartureDropoff")
  places         Place[]

  @@index([isActive, sortOrder])
}

/// Fixed Madaraka timetable + van buffer per zone (admin CRUD).
model SgrScheduleSlot {
  id                    String              @id @default(cuid())
  pickupLocationId      String
  pickupLocation        CorridorLocation    @relation("SlotPickup", fields: [pickupLocationId], references: [id], onDelete: Cascade)
  dropoffLocationId     String
  dropoffLocation       CorridorLocation    @relation("SlotDropoff", fields: [dropoffLocationId], references: [id], onDelete: Cascade)
  direction             SharedRideDirection
  trainService          SgrTrainService
  /// Train departs Miritini (to_sgr) or arrives at Miritini (from_sgr), HH:mm Nairobi.
  sgrEventTime          String              @db.VarChar(5)
  vanDepartureTime      String              @db.VarChar(5)
  suggestedPricePerSeat Int
  sortOrder             Int                 @default(0)
  isActive              Boolean             @default(true)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  departures   SharedDeparture[]
  tripRequests SharedTripRequest[]

  @@unique([pickupLocationId, dropoffLocationId, trainService, direction, sgrEventTime, vanDepartureTime])
  @@index([pickupLocationId, dropoffLocationId, direction, isActive])
}

enum SharedTripRequestStatus {
  open
  matched
  cancelled
  expired
}

enum SharedTripRequestReservationStatus {
  active
  cancelled
}

/// Pooled passenger intent for a slot + van departure (Laravel TripRequest).
model SharedTripRequest {
  id                   String                  @id @default(cuid())
  sgrScheduleSlotId    String
  sgrScheduleSlot      SgrScheduleSlot         @relation(fields: [sgrScheduleSlotId], references: [id], onDelete: Cascade)
  /// Van departure instant (UTC). Direction, corridor zone, and Nairobi calendar day are derived from slot + this instant.
  requestedDepartureAt DateTime
  seatsRequested       Int                     @default(0)
  status               SharedTripRequestStatus @default(open)
  matchedDepartureId   String?
  matchedDeparture     SharedDeparture?        @relation(fields: [matchedDepartureId], references: [id], onDelete: SetNull)
  notes                String?                 @db.Text
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  reservations SharedTripRequestReservation[]

  @@index([sgrScheduleSlotId, requestedDepartureAt, status])
}

/// One passenger's seat count on a pooled trip request (Laravel TripRequestReservation).
model SharedTripRequestReservation {
  id             String                               @id @default(cuid())
  tripRequestId  String
  tripRequest    SharedTripRequest                    @relation(fields: [tripRequestId], references: [id], onDelete: Cascade)
  passengerId    String
  passenger      User                                 @relation("PassengerTripRequestReservations", fields: [passengerId], references: [id], onDelete: Cascade)
  seatsRequested Int
  status         SharedTripRequestReservationStatus   @default(active)
  pickupNote     String?                              @db.VarChar(200)
  createdAt      DateTime                             @default(now())
  updatedAt      DateTime                             @updatedAt

  @@unique([tripRequestId, passengerId])
  @@index([passengerId, status])
}

/// Scheduled shared van run (Laravel Trip).
model SharedDeparture {
  id                  String                @id @default(cuid())
  driverId            String?
  driver              User?                 @relation("DriverSharedDepartures", fields: [driverId], references: [id], onDelete: SetNull)
  /// Vehicle snapshot when the departure was opened (seat grid source).
  vehicleId           String?
  vehicle             Vehicle?              @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  pickupLocationId    String
  pickupLocation      CorridorLocation      @relation("DeparturePickup", fields: [pickupLocationId], references: [id])
  dropoffLocationId   String
  dropoffLocation     CorridorLocation      @relation("DepartureDropoff", fields: [dropoffLocationId], references: [id])
  sgrScheduleSlotId   String?
  sgrScheduleSlot     SgrScheduleSlot?      @relation(fields: [sgrScheduleSlotId], references: [id], onDelete: SetNull)
  departureAt         DateTime
  pricePerSeat        Int
  /// Seat count for this run; Phase 4 should align with driver Vehicle.seats when driver publishes.
  capacity            Int                   @default(14)
  status              SharedDepartureStatus @default(scheduled)
  /// Live van position while serving passengers (Laravel Trip.driver_lat/lng).
  driverLat             Float?
  driverLng             Float?
  driverLocationUpdatedAt DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  seats               SharedDepartureSeat[]
  matchedTripRequests SharedTripRequest[]
  bookings            Booking[]

  @@index([status, departureAt])
  @@index([pickupLocationId, dropoffLocationId, departureAt])
}

enum SharedDepartureSeatStatus {
  available
  reserved
  paid
  disabled
}

model SharedDepartureSeat {
  id           String                    @id @default(cuid())
  departureId  String
  departure    SharedDeparture           @relation(fields: [departureId], references: [id], onDelete: Cascade)
  seatNumber   Int
  /// Display label (A1, B2). `seatNumber` is the bookable index for API reserve.
  seatLabel    String            @default("")
  row          Int?
  col          Int?
  status       SharedDepartureSeatStatus @default(available)
  reservedById String?
  reservedBy   User?                     @relation("ReservedDepartureSeats", fields: [reservedById], references: [id], onDelete: SetNull)
  reservedAt   DateTime?
  expiresAt    DateTime?
  bookingId    String?
  booking      Booking?                  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  bookingSeatRows BookingSeat[]
  /// Neighborhood pickup pin for this passenger (label + coordinates).
  pickupLabel  String?                   @db.VarChar(200)
  pickupLat    Float?
  pickupLng    Float?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  @@unique([departureId, seatNumber])
  @@index([departureId, status])
  @@index([bookingId])
}
