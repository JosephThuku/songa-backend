// NEW — full initial schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  passenger
  driver
  admin
}

enum OnboardingStatus {
  pending
  approved
  rejected
}

enum RidePhase {
  finding_driver
  driver_accepted
  driver_en_route
  driver_arriving
  driver_arrived
  trip_in_progress
  trip_ended
  cancelled
}

enum BookingMode {
  seat_selection
  pay_on_arrival
}

enum RideEventActor {
  passenger
  driver
  system
}

enum BookingStatus {
  pending_payment
  paid
  failed
  cancelled
}

enum PaymentStatus {
  pending
  succeeded
  failed
}

enum SavedPlaceKind {
  home
  work
  other
}

model User {
  id            String    @id @default(cuid())
  phone         String
  role          UserRole
  name          String?
  email         String?
  passwordHash  String?
  phoneVerified Boolean   @default(false)
  avatarUrl     String?
  rating        Float     @default(5.0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  driverProfile      DriverProfile?
  sessions           Session[]
  passengerRides     Ride[]              @relation("PassengerRides")
  driverRides        Ride[]              @relation("DriverRides")
  rideEvents         RideEvent[]
  bookings           Booking[]
  walletTransactions WalletTransaction[]
  notifications      Notification[]
  devices            Device[]
  savedPlaces              SavedPlace[]
  paymentMethods           PaymentMethodPreference[]
  driverSharedDepartures        SharedDeparture[]              @relation("DriverSharedDepartures")
  reservedDepartureSeats        SharedDepartureSeat[]          @relation("ReservedDepartureSeats")
  sharedTripRequestReservations SharedTripRequestReservation[] @relation("PassengerTripRequestReservations")

  @@unique([phone, role]) // one human can be both passenger AND driver on same #
  @@unique([email, role]) // null emails allowed; uniqueness only enforced when set
  @@index([phone])
}

model DriverProfile {
  id                String           @id @default(cuid())
  userId            String           @unique
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  isOnline          Boolean          @default(false)
  acceptanceRate    Int              @default(100)
  onboardingStatus  OnboardingStatus @default(approved)
  vehicleId         String?
  vehicle           Vehicle?         @relation(fields: [vehicleId], references: [id])
  location          Json?
  locationUpdatedAt DateTime?
  onlineSince       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model Vehicle {
  id             String          @id @default(cuid())
  type           String
  make           String
  model          String
  registration   String          @unique
  color          String
  year           String?
  seats          Int             @default(4)
  status         String          @default("Activated")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  driverProfiles DriverProfile[]
}

model Ride {
  id               String          @id
  tripId           String?
  vehicleType      String?
  passengerId      String
  passenger        User            @relation("PassengerRides", fields: [passengerId], references: [id])
  driverId         String?
  driver           User?           @relation("DriverRides", fields: [driverId], references: [id])
  phase            RidePhase       @default(finding_driver)
  bookingMode      BookingMode
  prepaid          Boolean         @default(false)
  bookingId        String?
  paymentMethod    String?
  price            Int
  currency         String          @default("KES")
  etaMinutes       Int?
  distanceKm       Float?
  driverProgress   Float           @default(0)
  passengerBoarded Boolean         @default(false)
  seats            String?
  pickup           Json
  dropoff          Json
  driverLocation   Json?
  cancelReason            Json?
  cancelledByRole         RideEventActor?
  passengerDriverRating   Int?
  createdAt               DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  events           RideEvent[]
  declinedBy       String          @default("[]") @db.VarChar(4096)

  @@index([passengerId, phase])
  @@index([driverId, phase])
  @@index([phase, createdAt])
}

model RideEvent {
  id       String         @id @default(cuid())
  rideId   String
  ride     Ride           @relation(fields: [rideId], references: [id], onDelete: Cascade)
  actor    RideEventActor
  actorId  String?
  user     User?          @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action   String
  phase    RidePhase
  metadata Json?
  at       DateTime       @default(now())

  @@index([rideId, at])
}

model Booking {
  id          String        @id
  passengerId String
  passenger   User          @relation(fields: [passengerId], references: [id], onDelete: Cascade)
  tripId      String?
  status      BookingStatus @default(pending_payment)
  seats       String?
  subtotal    Int
  platformFee Int           @default(50)
  total       Int
  currency    String        @default("KES")
  pickup      Json
  dropoff     Json
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  payments    Payment[]

  @@index([passengerId, status])
}

model Payment {
  id                      String        @id
  bookingId               String
  booking                 Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider                String
  status                  PaymentStatus @default(pending)
  checkoutUrl             String?
  reference               String        @unique
  mpesaCheckoutRequestId  String?       @unique
  transactionRef          String?       @unique
  gatewayResponse         Json?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@index([bookingId, createdAt])
}

model WalletTransaction {
  id        String   @id
  driverId  String
  driver    User     @relation(fields: [driverId], references: [id], onDelete: Cascade)
  rideId    String?
  type      String
  label     String
  amount    Int
  currency  String   @default("KES")
  status    String   @default("posted")
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([driverId, createdAt])
  @@index([rideId])
}

model Notification {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String
  deepLink  String?
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Device {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushToken String   @unique
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model OtpAttempt {
  id        String   @id @default(cuid())
  phone     String
  ip        String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
  @@index([ip, createdAt])
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // SHA-256 of the JWT, for revocation lookup
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model SavedPlace {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  kind      SavedPlaceKind @default(other)
  placeId   String?
  lat       Float
  lng       Float
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId, createdAt])
}

model PaymentMethodPreference {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  isDefault  Boolean  @default(false)
  mpesaPhone String?
  cardLast4  String?
  cardBrand  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, type])
  @@index([userId])
}

// --- Shared SGR / coast corridor (see docs/SHARED_RIDES_PHASE1.md) ---

enum SharedRideDirection {
  to_sgr
  from_sgr
}

enum SgrTrainService {
  inter_county
  express
  night
}

enum SharedDepartureStatus {
  scheduled
  boarding
  completed
  cancelled
}

/// Neighborhood zone or fixed SGR Miritini stop (admin CRUD).
model CorridorLocation {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String   @unique
  lat       Float?
  lng       Float?
  radiusM   Int      @default(2500)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pickupSlots   SgrScheduleSlot[] @relation("SlotPickup")
  dropoffSlots  SgrScheduleSlot[] @relation("SlotDropoff")
  departuresFrom SharedDeparture[] @relation("DeparturePickup")
  departuresTo   SharedDeparture[] @relation("DepartureDropoff")
  tripRequests   SharedTripRequest[]

  @@index([isActive, sortOrder])
}

/// Fixed Madaraka timetable + van buffer per zone (admin CRUD).
model SgrScheduleSlot {
  id                    String              @id @default(cuid())
  pickupLocationId      String
  pickupLocation        CorridorLocation    @relation("SlotPickup", fields: [pickupLocationId], references: [id], onDelete: Cascade)
  dropoffLocationId     String
  dropoffLocation       CorridorLocation    @relation("SlotDropoff", fields: [dropoffLocationId], references: [id], onDelete: Cascade)
  direction             SharedRideDirection
  trainService          SgrTrainService
  /// Train departs Miritini (to_sgr) or arrives at Miritini (from_sgr), HH:mm Nairobi.
  sgrEventTime          String              @db.VarChar(5)
  vanDepartureTime      String              @db.VarChar(5)
  suggestedPricePerSeat Int
  sortOrder             Int                 @default(0)
  isActive              Boolean             @default(true)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  departures   SharedDeparture[]
  tripRequests SharedTripRequest[]

  @@unique([pickupLocationId, dropoffLocationId, trainService, direction, sgrEventTime, vanDepartureTime])
  @@index([pickupLocationId, dropoffLocationId, direction, isActive])
}

enum SharedTripRequestStatus {
  open
  matched
  cancelled
  expired
}

enum SharedTripRequestReservationStatus {
  active
  cancelled
}

/// Pooled passenger intent for a slot + van departure (Laravel TripRequest).
model SharedTripRequest {
  id                   String                  @id @default(cuid())
  sgrScheduleSlotId    String
  sgrScheduleSlot      SgrScheduleSlot         @relation(fields: [sgrScheduleSlotId], references: [id], onDelete: Cascade)
  corridorLocationId   String
  corridorLocation     CorridorLocation        @relation(fields: [corridorLocationId], references: [id])
  direction            SharedRideDirection
  /// Van departure instant (UTC).
  requestedDepartureAt DateTime
  /// Nairobi calendar day (YYYY-MM-DD) for display and queries.
  departureDate        String                  @db.VarChar(10)
  seatsRequested       Int                     @default(0)
  status               SharedTripRequestStatus @default(open)
  matchedDepartureId   String?
  matchedDeparture     SharedDeparture?        @relation(fields: [matchedDepartureId], references: [id], onDelete: SetNull)
  notes                String?                 @db.Text
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  reservations SharedTripRequestReservation[]

  @@index([sgrScheduleSlotId, requestedDepartureAt, status])
  @@index([corridorLocationId, direction, status])
}

/// One passenger's seat count on a pooled trip request (Laravel TripRequestReservation).
model SharedTripRequestReservation {
  id             String                               @id @default(cuid())
  tripRequestId  String
  tripRequest    SharedTripRequest                    @relation(fields: [tripRequestId], references: [id], onDelete: Cascade)
  passengerId    String
  passenger      User                                 @relation("PassengerTripRequestReservations", fields: [passengerId], references: [id], onDelete: Cascade)
  seatsRequested Int
  status         SharedTripRequestReservationStatus   @default(active)
  pickupNote     String?                              @db.VarChar(200)
  createdAt      DateTime                             @default(now())
  updatedAt      DateTime                             @updatedAt

  @@unique([tripRequestId, passengerId])
  @@index([passengerId, status])
}

/// Scheduled shared van run (Laravel Trip).
model SharedDeparture {
  id                  String                @id @default(cuid())
  driverId            String?
  driver              User?                 @relation("DriverSharedDepartures", fields: [driverId], references: [id], onDelete: SetNull)
  pickupLocationId    String
  pickupLocation      CorridorLocation      @relation("DeparturePickup", fields: [pickupLocationId], references: [id])
  dropoffLocationId   String
  dropoffLocation     CorridorLocation      @relation("DepartureDropoff", fields: [dropoffLocationId], references: [id])
  sgrScheduleSlotId   String?
  sgrScheduleSlot     SgrScheduleSlot?      @relation(fields: [sgrScheduleSlotId], references: [id], onDelete: SetNull)
  departureAt         DateTime
  pricePerSeat        Int
  /// Seat count for this run; Phase 4 should align with driver Vehicle.seats when driver publishes.
  capacity            Int                   @default(14)
  status              SharedDepartureStatus @default(scheduled)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  seats              SharedDepartureSeat[]
  matchedTripRequests SharedTripRequest[]

  @@index([status, departureAt])
  @@index([pickupLocationId, dropoffLocationId, departureAt])
}

enum SharedDepartureSeatStatus {
  available
  reserved
  paid
  disabled
}

model SharedDepartureSeat {
  id           String                    @id @default(cuid())
  departureId  String
  departure    SharedDeparture           @relation(fields: [departureId], references: [id], onDelete: Cascade)
  seatNumber   Int
  row          Int?
  col          Int?
  status       SharedDepartureSeatStatus @default(available)
  reservedById String?
  reservedBy   User?                     @relation("ReservedDepartureSeats", fields: [reservedById], references: [id], onDelete: SetNull)
  reservedAt   DateTime?
  expiresAt    DateTime?
  bookingId    String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  @@unique([departureId, seatNumber])
  @@index([departureId, status])
}
